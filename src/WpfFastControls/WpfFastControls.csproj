<Project Sdk="Microsoft.NET.Sdk">
  <PropertyGroup>
    <TargetFramework>net9.0-windows</TargetFramework>
    <UseWPF>true</UseWPF>
    <Nullable>enable</Nullable>
    <ImplicitUsings>enable</ImplicitUsings>
    <RootNamespace>WpfFastControls</RootNamespace>
    <AssemblyName>WpfFastControls</AssemblyName>
    <Version>1.0.0</Version>
    <Description>WPF control that skips the layout pass on text change — render-only updates for high-frequency displays.</Description>
  </PropertyGroup>
</Project>
